# Copy to .env.local and fill in real values. Never commit .env.local.

# better-auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# GitHub OAuth app (callback: <BETTER_AUTH_URL>/api/auth/callback/github)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Leaderboard data source: mock (default) | lambda | upstash
LEADERBOARD_SOURCE=mock

# Only used when LEADERBOARD_SOURCE=lambda
LEADERBOARD_API_URL=

# Used when LEADERBOARD_SOURCE=upstash, and by team writes when
# TEAM_WRITES_ENABLED=true (which requires a READ/WRITE token).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# "true" makes team join/create/leave write real records to Upstash Redis
# (needs the UPSTASH_REDIS_REST_* vars above); unset uses a per-browser
# cookie mock instead.
TEAM_WRITES_ENABLED=
