# Copy to .env.local and fill in real values. Never commit .env.local.

# better-auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# GitHub OAuth app (callback: <BETTER_AUTH_URL>/api/auth/callback/github)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Leaderboard data source: mock (default) | lambda | upstash
LEADERBOARD_SOURCE=mock

# Base URL of the scoring API (serves /leaderboard and /challenges).
# Required when LEADERBOARD_SOURCE=lambda; the challenges page also uses it
# for the live challenge catalogue and falls back to static cards without it.
LEADERBOARD_API_URL=

# Used when LEADERBOARD_SOURCE=upstash, by team writes when
# TEAM_WRITES_ENABLED=true, and by paid hints when HINTS_ENABLED=true
# (writes need a READ/WRITE token).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# "true" turns on paid hints on /challenges (needs the UPSTASH_REDIS_REST_*
# vars above with a READ/WRITE token — revealing a hint writes the purchase
# to Upstash). Leave unset until the event so contestants can't buy hints
# early; without it the hint layer is invisible.
HINTS_ENABLED=

# "true" makes team join/create/leave write real records to Upstash Redis
# (needs the UPSTASH_REDIS_REST_* vars above); unset uses a per-browser
# cookie mock instead.
TEAM_WRITES_ENABLED=

# Which store backs team + hint state (only matters when the flags above are
# on): dual (default, incl. unset) writes Upstash as the source of truth AND
# mirrors every success into DynamoDB; upstash disables the DynamoDB side;
# dynamo makes DynamoDB the only store — writes AND reads, including hint text
# and availability from pk=HINTS (populated by `pnpm backfill:dynamo --apply`;
# re-run it after any hint re-seeding), so hints need no UPSTASH_REDIS_REST_*
# vars in dynamo mode.
CTF_DATA_BACKEND=

# "true" locks /challenges behind the pre-event password gate: visitors are
# redirected to /gate until they enter CHALLENGES_GATE_PASSWORD (verified
# server-side; 5 wrong tries lock the IP for 24h via DynamoDB). Needs
# BETTER_AUTH_SECRET (signs the unlock cookie). Flip to false and redeploy
# when the conference starts.
CHALLENGES_GATE_ENABLED=
CHALLENGES_GATE_PASSWORD=

# DynamoDB overrides — all have working hardcoded defaults (see src/lib/dynamo.ts),
# so normally leave these unset. On Vercel, credentials come from Vercel OIDC
# (no keys anywhere); locally the AWS SDK default chain is used — run
# `aws sso login` and set AWS_PROFILE in your shell (not here).
# CTF_AWS_REGION is deliberately not the standard AWS_REGION: Vercel injects
# that with the function's own execution region, not where the table lives.
# CTF_AWS_REGION=us-west-2
# AWS_ROLE_ARN=arn:aws:iam::942548380662:role/ctf-web-dynamodb
# CTF_DYNAMO_TABLE=ctf-leaderboard
