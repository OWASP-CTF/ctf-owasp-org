# Copy to .env.local and fill in real values. Never commit .env.local.

# better-auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# GitHub OAuth app (callback: <BETTER_AUTH_URL>/api/auth/callback/github)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Leaderboard data source: mock (default) | lambda | upstash
LEADERBOARD_SOURCE=mock

# Base URL of the scoring API (serves /leaderboard and /challenges).
# Required when LEADERBOARD_SOURCE=lambda; the challenges page also uses it
# for the live challenge catalogue and falls back to static cards without it.
LEADERBOARD_API_URL=

# Used when LEADERBOARD_SOURCE=upstash, and by team writes when
# TEAM_WRITES_ENABLED=true (which requires a READ/WRITE token).
# Paid hints on /challenges activate automatically when these are set —
# revealing a hint writes the purchase to Upstash, so the token must be
# READ/WRITE (already required for TEAM_WRITES_ENABLED). Without these vars
# the hint layer is invisible.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# "true" makes team join/create/leave write real records to Upstash Redis
# (needs the UPSTASH_REDIS_REST_* vars above); unset uses a per-browser
# cookie mock instead.
TEAM_WRITES_ENABLED=
